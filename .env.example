# App
NODE_ENV=development
PORT=3001
APP_ORIGIN=http://localhost:3000
APP_DATA_DIR=./data
SESSION_COOKIE_DOMAIN=
APP_STORAGE_DRIVER=json
APP_DATABASE_PATH=
APP_SQLITE_JSON_MIRROR=true

# SMTP for email verification, magic link, and password reset
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=CVsolucion
CONTACT_EMAIL=contact@cvsolucion.com

# Optional: comma-separated admin emails allowed to open /dashboard
ADMIN_EMAILS=

# Optional OpenAI chatbot
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-5-mini
OPENAI_TRANSLATION_MODEL=
OPENAI_CHAT_SYSTEM_PROMPT=

# Optional Stripe payments
STRIPE_SECRET_KEY=
VITE_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CURRENCY=usd
STRIPE_CARD_PAYMENT_FEE_CENTS=1500
STRIPE_PRICE_STANDARD_CONSULTATION=14000
STRIPE_PRICE_STANDARD_SUPPORT=14000
STRIPE_PRICE_EXPRESS_CONSULTATION=18000
STRIPE_PRICE_EXPRESS_SUPPORT=18000
STRIPE_PRICE_TRAINING_LEVEL_1=59700
STRIPE_PRICE_TRAINING_LEVEL_2=99700
STRIPE_PRICE_TRAINING_LEVEL_3=129700
STRIPE_PRICE_TRAINING_LEVEL_4=149700
STRIPE_PRICE_TRAINING_BUNDLE=399700

# Optional analytics
VITE_ENABLE_GTM=false
VITE_GTM_ID=
VITE_GA4_ID=
VITE_UMAMI_URL=
VITE_UMAMI_WEBSITE_ID=
VITE_ANALYTICS_ENDPOINT=
VITE_ANALYTICS_WEBSITE_ID=

# Optional GA4 Data API for dashboard reporting
GA4_PROPERTY_ID=
GA4_SERVICE_ACCOUNT_PATH=
GA4_SERVICE_ACCOUNT_JSON=

# Optional public integrations
VITE_BOOKING_URL=
VITE_OAUTH_PORTAL_URL=
VITE_APP_ID=
VITE_FRONTEND_FORGE_API_KEY=
VITE_FRONTEND_FORGE_API_URL=

# Optional Bing Webmaster verification
# Use either:
# - BING_SITE_VERIFICATION (for <meta name="msvalidate.01" ...>)
# - BING_SITE_AUTH_TOKEN (for /BingSiteAuth.xml)
# - BING_SITE_AUTH_XML (full XML body if Bing provides custom format)
BING_SITE_VERIFICATION=
BING_SITE_AUTH_TOKEN=
BING_SITE_AUTH_XML=
